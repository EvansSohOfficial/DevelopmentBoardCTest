void gimbal_control(void *argument)
{
    osDelay(500);
    CAN1_Init_Filters();

    // Send test frame
    GM6020_SendControl(&hcan1, 1000, 0, 0, 0);
    osDelay(100);

    while(1)
    {
        GM6020_SendControl(&hcan1, 1000, 0, 0, 0);

        uint32_t error = HAL_CAN_GetError(&hcan1);
        uint32_t fifo  = HAL_CAN_GetRxFifoFillLevel(&hcan1, CAN_RX_FIFO0);

        if (error != HAL_CAN_ERROR_NONE)
        {
            // Error — very fast blink
            HAL_GPIO_TogglePin(GPIOH, GPIO_PIN_12);
            osDelay(50);
        }
        else if (fifo > 0)
        {
            // Loopback received — solid LED ✅
            HAL_GPIO_WritePin(GPIOH, GPIO_PIN_12, GPIO_PIN_SET);
            osDelay(10);
        }
        else
        {
            // No error no data — slow blink
            HAL_GPIO_TogglePin(GPIOH, GPIO_PIN_12);
            osDelay(500);
        }
    }
}
